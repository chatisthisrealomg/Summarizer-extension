{
  "manifest_version": 3,
  "name": "summarizer extension",
  "version": "1.0",
  "description": "Extension with implemented AI that will summarize webpages and articles",
  "permissions": ["storage", "activeTab", "scripting", "tabs"],
  "host_permissions": [
    "https://api.groq.com/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
